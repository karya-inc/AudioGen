# ElevenLabs
ELEVENLABS_API_KEY=sk-...

# Google service account credentials file path
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json

# Google Sheet ID (from the sheet URL)
GOOGLE_SHEET_ID=

# Google Drive folder ID where AudioAssets/ will be created
GOOGLE_DRIVE_FOLDER_ID=

# Delay in seconds between ElevenLabs API calls (default: 1.0)
RATE_LIMIT_DELAY=1.0
